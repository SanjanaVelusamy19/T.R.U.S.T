# TRUST Monitoring Service — service discovery URLs
# Copy to `.env` when running outside Docker Compose.

AUTH_SERVICE_URL=http://localhost:8001
LOAN_SERVICE_URL=http://localhost:8002
TRUST_SCORE_SERVICE_URL=http://localhost:8003
ADVISOR_SERVICE_URL=http://localhost:8004
FRAUD_DETECTION_SERVICE_URL=http://localhost:8005
GATEWAY_SERVICE_URL=http://localhost:8000

# Self-healing probe settings
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_TIMEOUT_SEC=4.0
LATENCY_WARNING_DELTA_MS=15
