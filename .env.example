# TRUST — Microservices Fintech System
# Copy to `.env` and adjust values before running Docker Compose or local services.

# --- Shared JWT configuration (gateway + auth-service must match) ---
JWT_SECRET=change-me-in-production-use-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Gateway ---
AUTH_SERVICE_URL=http://auth-service:8001
LOAN_SERVICE_URL=http://loan-service:8002
TRUST_SCORE_SERVICE_URL=http://trust-score-service:8003
ADVISOR_SERVICE_URL=http://advisor-service:8004
FRAUD_DETECTION_SERVICE_URL=http://fraud-detection-service:8005
DIGITAL_TWIN_SERVICE_URL=http://digital-twin-service:8007
RATE_LIMIT_DEFAULT=100/minute

# --- React build (browser calls host-published gateway port) ---
VITE_API_URL=http://localhost:8000

# --- Auth database (optional override; default is SQLite under AUTH_DATA_DIR) ---
# DATABASE_URL=sqlite:////app/data/trust_auth.db
# AUTH_DATA_DIR=./data
